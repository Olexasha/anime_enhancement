# Рабочие параметры
RESOLUTION=4K
START_BATCH_TO_IMPROVE=1
END_BATCH_TO_IMPROVE=0
FRAMES_PER_BATCH=1000
OUTPUT_IMAGE_FORMAT=png

# AI stages
ENABLE_DENOISE=false
ENABLE_INTERPOLATION=true
REALESRGAN_MODEL_NAME=realesr-animevideov3
UPSCALE_FACTOR=3
FRAMES_MULTIPLY_FACTOR=3
ENABLE_UHD_MODE=true
ENABLE_SPATIAL_TTA_MODE=false
ENABLE_TEMPORAL_TTA_MODE=true

# Short-video transport: RGB lossless, без YUV-конвертации до final encode.
INTERMEDIATE_VIDEO_ENCODER=libx264rgb
INTERMEDIATE_VIDEO_CRF=0
INTERMEDIATE_VIDEO_PRESET=ultrafast
INTERMEDIATE_VIDEO_PIX_FMT=bgr24
INTERMEDIATE_VIDEO_CONTAINER=mkv

# Final encode: один encode из clean short в качественный 4:4:4 H.264.
VIDEO_ENCODER=libx264
VIDEO_CRF=10
VIDEO_PRESET=slow
VIDEO_TUNE=animation
VIDEO_PIX_FMT=yuv444p

# Diagnostics
KEEP_TEMP_FILES=false
