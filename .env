# Файловые параметры апскейлера
RESOLUTION=4K
START_BATCH_TO_IMPROVE=1
END_BATCH_TO_IMPROVE=0
FRAMES_PER_BATCH=1000
OUTPUT_IMAGE_FORMAT=png

# denoise выключен: он съедает слабые линии и детали
ENABLE_DENOISE=false
# Интерполяция включена по умолчанию для финального плавного результата.
ENABLE_INTERPOLATION=true

# Апскейл
REALESRGAN_MODEL_NAME=realesr-animevideov3
UPSCALE_FACTOR=3

# Денойз оставлен только как ручная опция для сильно шумных исходников.
DENOISE_FACTOR=1
WAIFU2X_UPSCALE_FACTOR=1

# Кодирование видео
# Максимальное качество: VIDEO_ENCODER=libx264 и VIDEO_CRF=16
# Быстрее: VIDEO_ENCODER=h264_nvenc и VIDEO_NVENC_CQ=15
VIDEO_ENCODER=libx264
VIDEO_CRF=16
VIDEO_PRESET=slow
VIDEO_NVENC_CQ=15
VIDEO_PIX_FMT=yuv420p

# Интерполяция
FRAMES_MULTIPLY_FACTOR=3
ENABLE_UHD_MODE=True
ENABLE_SPATIAL_TTA_MODE=False
ENABLE_TEMPORAL_TTA_MODE=True
